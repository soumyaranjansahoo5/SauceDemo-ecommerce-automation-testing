<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<!--
  E-Commerce Automation Test Suite
  Run with: mvn test
  To run only smoke:     mvn test -Dgroups=smoke
  To run only api:       mvn test -Dgroups=api
  To run only e2e:       mvn test -Dgroups=e2e
  To run in Firefox:     mvn test -Dbrowser=firefox
-->

<suite name="ECommerce-Automation-Suite" verbose="2" parallel="methods" thread-count="3">

    <parameter name="browser" value="chrome"/>

    <!-- ── Smoke Tests ─────────────────────────────────────────────────── -->
    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.ecommerce.tests.LoginTest"/>
            <class name="com.ecommerce.tests.ProductTest"/>
            <class name="com.ecommerce.tests.CartTest"/>
            <class name="com.ecommerce.tests.CheckoutTest"/>
            <class name="com.ecommerce.api.ProductApiTest"/>
            <class name="com.ecommerce.api.CartApiTest"/>
            <class name="com.ecommerce.api.OrderApiTest"/>
        </classes>
    </test>

    <!-- ── Regression Tests ────────────────────────────────────────────── -->
    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.ecommerce.tests.LoginTest"/>
            <class name="com.ecommerce.tests.ProductTest"/>
            <class name="com.ecommerce.tests.CartTest"/>
            <class name="com.ecommerce.tests.CheckoutTest"/>
        </classes>
    </test>

    <!-- ── API Tests ───────────────────────────────────────────────────── -->
    <test name="API Tests">
        <groups>
            <run>
                <include name="api"/>
            </run>
        </groups>
        <classes>
            <class name="com.ecommerce.api.ProductApiTest"/>
            <class name="com.ecommerce.api.CartApiTest"/>
            <class name="com.ecommerce.api.OrderApiTest"/>
        </classes>
    </test>

    <!-- ── End-to-End Tests ─────────────────────────────────────────────── -->
    <test name="End-to-End Tests">
        <groups>
            <run>
                <include name="e2e"/>
            </run>
        </groups>
        <classes>
            <class name="com.ecommerce.tests.CheckoutTest"/>
        </classes>
    </test>

</suite>
